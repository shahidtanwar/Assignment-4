def count_even_sum_odd(lst):
    even_count = 0
    odd_sum = 0

    for num in lst:
        if num % 2 == 0:
            even_count += 1
        else:
            odd_sum += num

    return even_count, odd_sum


numbers = [1, 2, 3, 4, 5, 6, 7]
even_count, odd_sum = count_even_sum_odd(numbers)

print("Count of even numbers:", even_count)
print("Sum of odd numbers:", odd_sum)
